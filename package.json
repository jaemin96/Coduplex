{
  "name": "coduplex",
  "version": "1.2.1",
  "private": true,
  "engines": {
    "node": ">=24.13.1"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "pnpm -r --parallel run dev",
    "dev:apps": "turbo run dev --filter=./apps/*",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "prettier --write \"apps/**/*.{js,jsx,ts,tsx,json}\""
  },
  "devDependencies": {
    "@cx/eslint-config": "workspace:*",
    "@cx/prettier-config": "workspace:*",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "eslint": "^9.25.1",
    "prettier": "^3.5.0",
    "turbo": "^2.5.6",
    "typescript": "^5.8.3"
  }
}
